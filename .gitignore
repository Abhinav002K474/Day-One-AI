# ========================================
# Day One AI - .gitignore
# ========================================

# ==================
# Environment & Secrets
# ==================
.env
.env.local
.env.production
*.env

# IMPORTANT: Never commit API keys or database credentials!

# ==================
# Dependencies
# ==================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ==================
# Database
# ==================
*.sql
*.sqlite
*.db
*.mdb

# Ignore database dumps (unless intentional backup)
backup/*.sql
dumps/

# ==================
# Uploads & User Data
# ==================
uploads/
!uploads/.gitkeep

# Keep directory structure but ignore content
backend/uploads/profiles/*
!backend/uploads/profiles/.gitkeep
backend/uploads/study_materials/*
!backend/uploads/study_materials/.gitkeep
backend/uploads/question_banks/*
!backend/uploads/question_banks/.gitkeep

# ==================
# Logs
# ==================
logs/
*.log
npm-debug.log*
lerna-debug.log*
pnpm-debug.log*

# ==================
# OS Files
# ==================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Windows
$RECYCLE.BIN/

# Mac
.AppleDouble
.LSOverride

# ==================
# IDE & Editors
# ==================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Keep VSCode settings if you want to share
# !.vscode/settings.json
# !.vscode/extensions.json

# ==================
# Build & Distribution
# ==================
dist/
build/
*.tgz
*.zip
*.tar.gz

# ==================
# Testing
# ==================
coverage/
.nyc_output/
*.lcov

# ==================
# Temporary Files
# ==================
tmp/
temp/
*.tmp
*.bak
*.cache
*.pid
*.seed
*.pid.lock

# ==================
# Python (if using Python scripts)
# ==================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
ENV/

# ==================
# Misc
# ==================
.npmrc
.yarnrc
.nvmrc

# ==================
# Project Specific
# ==================

# Don't commit actual backend .env (use .env.example instead)
backend/.env

# Don't commit real API keys
config/secrets.js
config/keys.js

# Don't commit user-uploaded PDFs
*.pdf
!documentation/*.pdf
!example/*.pdf

# Don't commit session data
sessions/

# Don't commit PM2 logs (if using PM2)
.pm2/

# ==================
# Keep These Files (Documentation)
# ==================
!README.md
!STARTUP_GUIDE.md
!QUICK_REFERENCE.txt
!DEPLOYMENT.md
!ARCHITECTURE.md
!CHANGES_SUMMARY.md
!IMPLEMENTATION_COMPLETE.md
!DOCS_INDEX.md

# ==================
# Keep Configuration Templates
# ==================
!backend/.env.example
!config.example.js

# ==================
# Keep Empty Directory Markers
# ==================
!**/.gitkeep

# ==================
# For Production
# ==================
# If deploying to production, you may want to ignore:
# - Large files
# - Development tools
# - Test data

# ==================
# Notes
# ==================
# This .gitignore is configured for Day One AI Learning Platform
# - Protects sensitive data (.env, uploads, logs)
# - Keeps project structure clean
# - Allows sharing code safely
# - Maintains documentation
#
# Before committing, always review with: git status
.vercel
.env*.local
